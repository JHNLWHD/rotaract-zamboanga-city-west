{
  "name": "rotaract-zamboanga-city-west-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && vite build",
    "build:dev": "npm run type-check && vite build --mode development",
    "type-check": "tsc --noEmit",
    "lint": "npm run format && eslint . --fix",
    "lint:check": "npm run format:check && eslint .",
    "check-all": "npm run type-check && npm run lint:check",
    "format": "npx prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\" \"*.{js,ts,json,md}\" \"scripts/**/*.js\"",
    "format:check": "npx prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\" \"*.{js,ts,json,md}\" \"scripts/**/*.js\"",
    "preview": "vite preview",
    "contentful:validate": "node scripts/validate-contentful.js",
    "contentful:setup": "node scripts/setup-contentful-models.js",
    "contentful:delete": "node scripts/delete-content.js",
    "contentful:delete:force": "node scripts/delete-content.js --force",
    "contentful:delete:all": "node scripts/delete-content.js --force --include-homepage",
    "contentful:delete:dry-run": "node scripts/delete-content.js --dry-run",
    "contentful:upload-assets": "node scripts/upload-assets.js",
    "contentful:upload-assets:dry-run": "node scripts/upload-assets.js --dry-run",
    "contentful:migrate-homepage": "node scripts/migrate-homepage.js",
    "contentful:migrate-projects": "node scripts/migrate-projects.js",
    "contentful:migrate-events": "node scripts/migrate-events.js",
    "contentful:migrate-officers": "node scripts/migrate-officers.js",
    "migrate:all": "node scripts/migrate-all.js"
  },
